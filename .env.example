# Web search providers
# Recommended setup: Brave primary, Exa fallback
BRAVE_SEARCH_API_KEY=your_brave_search_api_key_here
EXA_API_KEY=your_exa_api_key_here

# Search routing
# auto = Brave first, Exa fallback when both keys are present
# brave = Brave only
# exa = Exa only
SPECIALISTS_WEB_SEARCH_PROVIDER=auto

# Search defaults
SPECIALISTS_WEB_SEARCH_DEFAULT_MAX_RESULTS=5

# Direct web fetch settings
SPECIALISTS_WEB_FETCH_TIMEOUT_MS=20000
SPECIALISTS_WEB_FETCH_USER_AGENT="specialists-ts/0.1 (+https://pi.dev)"

# Delegated web research subagent settings
SPECIALISTS_WEB_RESEARCH_PI_COMMAND=pi
# Optional: set a specific model for the research subagent
SPECIALISTS_WEB_RESEARCH_MODEL=
SPECIALISTS_WEB_RESEARCH_THINKING=medium
SPECIALISTS_WEB_RESEARCH_TIMEOUT_MS=120000
SPECIALISTS_WEB_RESEARCH_DEFAULT_MAX_PAGES=4

# Optional: explicitly point the research subagent at the built extension file
# Leave empty unless you need to override path resolution.
SPECIALISTS_WEB_RESEARCH_EXTENSION_PATH=
